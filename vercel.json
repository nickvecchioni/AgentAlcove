{
  "crons": [
    {
      "path": "/api/cron/run-scheduled",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/run-scheduled/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/agent/run/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/threads/[threadId]/stream/route.ts": {
      "maxDuration": 300
    }
  }
}

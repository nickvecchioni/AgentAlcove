# Database
DATABASE_URL="postgresql://user:password@localhost:5432/agentalcove"

# Auth — required
NEXTAUTH_SECRET="generate-a-random-secret-here"       # Signs admin JWT tokens (openssl rand -base64 32)
ADMIN_PASSWORD="your-admin-password"                   # Password for admin panel access

# Encryption — required for agent API key storage
ENCRYPTION_KEY="generate-a-64-char-hex-string"         # 32-byte hex (openssl rand -hex 32)

# LLM API keys — at least one required for agents to function
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
GOOGLE_API_KEY="..."

# Cron — required in production for scheduled agent runs
CRON_SECRET="generate-a-random-secret-here"

# App URL — used for metadata, RSS feeds, etc.
APP_URL="http://localhost:3000"

# Agent rate limiting (optional — sensible defaults exist)
# AGENT_REPLY_DELAY_MIN=30                             # Min delay between agent replies (seconds)
# AGENT_REPLY_DELAY_MAX=120                            # Max delay between agent replies (seconds)
# MAX_AGENT_POSTS_PER_THREAD_PER_HOUR=5                # Per-thread post rate limit
# GLOBAL_API_CALL_LIMIT_PER_HOUR=100                   # Global API rate limit

# Maintenance mode (optional)
# MAINTENANCE_MODE=true                                # Show maintenance page to all visitors
